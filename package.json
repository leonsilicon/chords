{
  "name": "chords",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    "./*": "./dist/*"
  },
  "scripts": {
    "build": "vp fmt src/ && vp check src/ && rimraf dist/ && bun build ./src/exports/* --outdir dist/ --root ./src/exports --target node --external chordsapp && bun build ./src/bin/* --outdir dist/bin/ --root ./src/bin --target bun && for f in dist/bin/*.js; do mv \"$f\" \"${f%.js}\"; done && chmod +x dist/bin/*",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@kayahr/text-encoding": "^2.1.0",
    "@stdlib/utils-noop": "^0.2.3",
    "@types/json-parse-safe": "^2.0.3",
    "any-ascii-json": "^0.4.0",
    "array-uniq": "^3.0.0",
    "bplist-lossless": "^0.2.0",
    "brace-expansion": "^5.0.4",
    "chrome-remote-interface": "^0.34.0",
    "decode-utf8": "^1.0.1",
    "desm": "^1.3.1",
    "doctor-json": "^1.0.0",
    "encode-utf8": "^2.0.0",
    "fast-is-equal": "^1.2.6",
    "filter-obj": "^6.1.0",
    "get-port": "^7.2.0",
    "jquery-as-string": "^0.4.0",
    "js-yaml": "^4.1.1",
    "json-parse-safe": "^2.0.0",
    "just-filter-object": "^3.2.0",
    "just-zip-it": "^3.2.0",
    "jxa-run-compat": "^1.5.0",
    "keycode-ts2": "^0.1.0",
    "map-obj": "^6.0.0",
    "nano-spawn-compat": "^2.0.6",
    "nullthrows-es": "^1.0.1",
    "onetime": "^8.0.0",
    "outdent": "^0.8.0",
    "type-fest": "^5.5.0",
    "untildify": "^6.0.0",
    "websocket": "^1.0.35"
  },
  "devDependencies": {
    "@electron/asar": "^4.1.0",
    "@jxa/global-type": "^1.4.0",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/websocket": "^1.0.10",
    "bun-types": "^1.3.11",
    "deep-object-diff": "^1.1.9",
    "lefthook": "^2.1.4",
    "llrt-types": "github:awslabs/llrt#path:/types",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
